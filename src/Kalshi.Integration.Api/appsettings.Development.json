{
  "ConnectionStrings": {
    "KalshiIntegration": "Data Source=kalshi-integration-event-publisher.dev.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Risk": {
    "MaxOrderSize": 10,
    "RejectDuplicateCorrelationIds": true
  },
  "Authentication": {
    "Jwt": {
      "SigningKey": "kalshi-integration-event-publisher-local-dev-signing-key-please-change",
      "EnableDevelopmentTokenIssuance": true
    }
  },
  "OpenApi": {
    "EnableSwaggerInNonDevelopment": false
  },
  "Integrations": {
    "NodeGateway": {
      "Enabled": true,
      "BaseUrl": "http://localhost:3001",
      "HealthPath": "/health",
      "TimeoutSeconds": 5,
      "RetryAttempts": 2,
      "IncludeInReadiness": false
    }
  },
  "OpenTelemetry": {
    "ServiceName": "Kalshi.Integration.Api",
    "ServiceVersion": "v1-dev",
    "OtlpEndpoint": null,
    "AzureMonitorConnectionString": null,
    "EnableConsoleExporter": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
